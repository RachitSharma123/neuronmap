---
const SUPA_URL = (import.meta.env.PUBLIC_SUPABASE_URL ?? "").trim();
const SUPA_KEY = (import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? "").trim();

// Injected as raw HTML — Astro will NOT process/bundle these script tags
const rawScripts = `
<script>window.NM={url:"${SUPA_URL}",key:"${SUPA_KEY}"};</script>
<script src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.js"></script>
<script src="/neuronmap.js" defer></script>
`;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Graph ✦ Explore the AI Universe</title>
    <meta name="description" content="The only AI glossary that teaches you connections, not just definitions." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Fragment set:html={rawScripts} />
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { background: #04040e; }
      body {
        width: 100%; height: 100%; overflow: hidden;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        color: #e2e8f0;
        position: relative;
      }
      body::before {
        content: '';
        position: fixed;
        inset: -40%;
        z-index: 0;
        transform-origin: center center;
        background:
          radial-gradient(ellipse 55% 40% at 20% 30%, rgba(120,40,255,0.55) 0%, transparent 50%),
          radial-gradient(ellipse 45% 50% at 80% 20%, rgba(20,90,240,0.48) 0%, transparent 48%),
          radial-gradient(ellipse 60% 40% at 60% 85%, rgba(220,30,120,0.42) 0%, transparent 46%),
          radial-gradient(ellipse 40% 45% at 85% 65%, rgba(0,180,230,0.32) 0%, transparent 44%),
          radial-gradient(ellipse 35% 35% at 30% 75%, rgba(160,60,255,0.38) 0%, transparent 40%);
        animation: bgOrbit 50s linear infinite;
      }
      @keyframes bgOrbit {
        from { transform: rotate(0deg) scale(1); }
        to   { transform: rotate(360deg) scale(1); }
      }
      #app { position: relative; z-index: 1; width: 100%; height: 100%; }
    </style>
  </head>
  <body>
    <div id="app"></div>
    <div style="position:fixed;bottom:18px;left:50%;transform:translateX(-50%);z-index:100;text-align:center;pointer-events:none;">
      <div style="font-size:13px;color:#a78bfa;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;margin-bottom:6px;text-shadow:0 0 20px rgba(167,139,250,0.6);">Crafted by Rachit Sharma</div>
      <div style="font-size:11px;color:#94a3b8;display:flex;gap:14px;justify-content:center;flex-wrap:wrap;">
        <a href="https://mode3.au" target="_blank" style="color:#c4b5fd;text-decoration:none;pointer-events:auto;font-weight:600;transition:color .2s;">mode3.au</a>
        <a href="https://www.aussieai.shop" target="_blank" style="color:#c4b5fd;text-decoration:none;pointer-events:auto;font-weight:600;transition:color .2s;">aussieai.shop</a>
        <a href="https://www.rachitsharma.space" target="_blank" style="color:#c4b5fd;text-decoration:none;pointer-events:auto;font-weight:600;transition:color .2s;">rachitsharma.space</a>
        <a href="https://www.rsharma.cv" target="_blank" style="color:#c4b5fd;text-decoration:none;pointer-events:auto;font-weight:600;transition:color .2s;">rsharma.cv</a>
      </div>
    </div>
  </body>
</html>
